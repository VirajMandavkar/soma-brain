# ============================================================
# SOMA Brain — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- API Keys (all free) ---
NCBI_API_KEY=your_ncbi_api_key_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here
HUGGINGFACE_TOKEN=your_hf_token_here

# --- Database Credentials ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=soma_brain_neo4j_2026

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=soma_brain
POSTGRES_USER=soma
POSTGRES_PASSWORD=soma_brain_pg_2026

WEAVIATE_URL=http://localhost:8080

REDIS_URL=redis://localhost:6379/0

# --- AI Model Config ---
# Gemini API (primary — works on any system, free tier)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# Ollama (optional — for systems with GPU, used as fallback)
OLLAMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma3:4b

# --- Modal (set via `modal token new`) ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- Application ---
SECRET_KEY=change_this_to_a_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8
LOG_LEVEL=INFO
